<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:text="Nano Solver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Permission + service status readouts -->
    <TextView
        android:id="@+id/tvOverlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"
        android:text="Overlay permission: checking…" />

    <TextView
        android:id="@+id/tvNotifStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"
        android:text="Notification permission: checking…" />

    <TextView
        android:id="@+id/tvServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"
        android:text="Overlay service: checking…" />

    <!-- Phase 2: shows whether the capture pipeline is active -->
    <TextView
        android:id="@+id/tvCaptureStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"
        android:text="Screen capture: checking…" />

    <!-- Phase 5: shows whether the accessibility service is enabled -->
    <TextView
        android:id="@+id/tvAccessibilityStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="32dp"
        android:text="Accessibility service: checking…" />

    <!-- Primary action: walks through all permissions then starts the solver -->
    <Button
        android:id="@+id/btnToggleService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Solver"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <!-- Secondary action: opens system Accessibility Settings -->
    <Button
        android:id="@+id/btnAccessibilitySettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
