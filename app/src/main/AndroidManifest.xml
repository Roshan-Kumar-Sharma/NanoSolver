<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        SYSTEM_ALERT_WINDOW: Required to draw the floating overlay on top of other apps.
        This is NOT requested via the normal runtime permission dialog — the user must be
        sent to a special Settings screen (Settings.ACTION_MANAGE_OVERLAY_PERMISSION).
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
        FOREGROUND_SERVICE: Required to run OverlayService as a foreground service.
        Without this, Android can kill the service when memory is low. Foreground services
        must show a persistent notification so the user knows the app is actively running.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        POST_NOTIFICATIONS: Required on API 33+ (Android 13+) to show notifications at all.
        Since our minSdk is 27, the code handles requesting this at runtime.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NanoSolver">

        <!-- The only Activity: shows permission status and a start/stop button -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            OverlayService runs as a foreground service.
            No foregroundServiceType needed for Phase 1 (overlay only).
            In Phase 2 we will add foregroundServiceType="mediaProjection" here
            alongside passing a MediaProjection token to startForeground().
            android:exported="false" means no other app can start this service directly.
        -->
        <service
            android:name=".service.OverlayService"
            android:exported="false" />

    </application>

</manifest>
