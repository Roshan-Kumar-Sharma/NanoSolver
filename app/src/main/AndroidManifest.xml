<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        SYSTEM_ALERT_WINDOW: Required to draw the floating overlay on top of other apps.
        This is NOT requested via the normal runtime permission dialog — the user must be
        sent to a special Settings screen (Settings.ACTION_MANAGE_OVERLAY_PERMISSION).
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
        FOREGROUND_SERVICE: Required to run OverlayService as a foreground service.
        Without this, Android can kill the service when memory is low. Foreground services
        must show a persistent notification so the user knows the app is actively running.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        FOREGROUND_SERVICE_MEDIA_PROJECTION: Required on API 34+ when a foreground service
        declares foregroundServiceType="mediaProjection". This is a normal permission
        (auto-granted at install). The actual runtime gate is the MediaProjection token
        obtained from MediaProjectionManager.createScreenCaptureIntent() user consent.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!--
        POST_NOTIFICATIONS: Required on API 33+ (Android 13+) to show notifications at all.
        Since our minSdk is 27, the code handles requesting this at runtime.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NanoSolver">

        <!-- The only Activity: shows permission status and a start/stop button -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            foregroundServiceType="mediaProjection": tells Android this service
            will use screen capture. On API 34, startForeground() with this type
            validates that the caller holds a valid MediaProjection token (obtained
            from user consent via createScreenCaptureIntent). The service is ONLY
            started after that consent is granted — never without a token.
        -->
        <service
            android:name=".service.OverlayService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <!--
            NanoAccessibilityService — Phase 5

            BIND_ACCESSIBILITY_SERVICE: only the Android system may bind to this
            service. Without android:permission, any app could bind and hijack
            our accessibility events. This is mandatory for security.

            android:exported="true": the system (not our app) starts this service,
            so it must be exported. The BIND_ACCESSIBILITY_SERVICE permission
            ensures only the system can actually bind it.

            The <meta-data> element points to res/xml/accessibility_service_config.xml
            which declares what events we receive and what capabilities we need.
        -->
        <service
            android:name=".service.NanoAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
